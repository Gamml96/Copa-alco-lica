rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny rule (except defined path structures)
    match /{document=**} {
      allow read, write: if false;
    }

    // Connection test document
    match /test/connection {
      allow read: if true;
    }

    // User Profile Rules (Public Read/Write)
    match /users/{userId} {
      allow read, write: if true;
    }

    // Room Rules (Public Read/Write)
    match /rooms/{roomId} {
      allow read, write: if true;
    }

    // Player Status in a Room
    match /rooms/{roomId}/players/{playerId} {
      allow read, write: if true;
    }

    // Bets in a Room
    match /rooms/{roomId}/bets/{betId} {
      allow read, write: if true;
    }

    // Messages / Logs in a Room
    match /rooms/{roomId}/messages/{messageId} {
      allow read, write: if true;
    }
  }
}
